<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (android:dataExtractionRules). Exclude the rebuildable audio
     cache from both cloud backup and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="audio" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="audio" />
    </device-transfer>
</data-extraction-rules>
