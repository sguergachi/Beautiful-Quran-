<?xml version="1.0" encoding="utf-8"?>
<!--
  App Actions + static launcher shortcuts.

  Capabilities map Google Assistant built-in intents to MainActivity.
  Inventory shortcuts (enabled=false) supply OPEN_APP_FEATURE feature names;
  enabled shortcuts also appear on long-press of the launcher icon.

  OPEN_APP_FEATURE lists a foreground intent first: while MainActivity is on
  screen, Assistant matches without the app name ("Open bookmarks", "Continue
  reading"). Background / cold start still needs "... on Beautiful Quran".
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- In-app search / open a verse by reference.
         GET_THING does not support foreground invocation — cold start only
         with app name: "search for 2:255 on Beautiful Quran". -->
    <capability android:name="actions.intent.GET_THING">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity">
            <parameter
                android:name="thing.name"
                android:key="q" />
        </intent>
    </capability>

    <!-- Named features: continue, bookmarks, save bookmark. -->
    <capability android:name="actions.intent.OPEN_APP_FEATURE">
        <!-- Foreground first: no app name while MainActivity is open. -->
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity">
            <parameter
                android:name="feature"
                android:key="feature" />
            <extra
                android:key="requiredForegroundActivity"
                android:value="com.beautifulquran/com.beautifulquran.MainActivity" />
        </intent>
        <!-- Background / cold start: "... on Beautiful Quran". -->
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity">
            <parameter
                android:name="feature"
                android:key="feature" />
        </intent>
    </capability>

    <!-- Inline inventory for OPEN_APP_FEATURE (Assistant matches spoken names). -->
    <shortcut
        android:shortcutId="continue"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_continue_short"
        android:shortcutLongLabel="@string/shortcut_continue_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity"
            android:data="beautifulquran://continue" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/assistant_continue_synonyms" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="bookmarks"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_bookmarks_short"
        android:shortcutLongLabel="@string/shortcut_bookmarks_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity"
            android:data="beautifulquran://bookmarks" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/assistant_bookmarks_synonyms" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="save_bookmark"
        android:enabled="false"
        android:shortcutShortLabel="@string/shortcut_save_bookmark_short"
        android:shortcutLongLabel="@string/shortcut_save_bookmark_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.beautifulquran"
            android:targetClass="com.beautifulquran.MainActivity"
            android:data="beautifulquran://bookmark/save" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/assistant_save_bookmark_synonyms" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="verse"
        android:enabled="false"
        android:shortcutShortLabel="@string/shortcut_verse_short"
        android:shortcutLongLabel="@string/shortcut_verse_long">
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/assistant_verse_synonyms" />
        </capability-binding>
    </shortcut>
</shortcuts>
