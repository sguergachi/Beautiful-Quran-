<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BeautifulQuran" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.BeautifulQuran.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0E5C4A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.BeautifulQuran</item>
    </style>
</resources>
